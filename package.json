{
  "name": "sentinel-scan",
  "version": "0.1.0",
  "private": true,
  "description": "SentinelScan — enterprise SaaS web application security scanner powered by Claude Opus 4.8 dynamic workflows",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx watch src/worker/index.ts",
    "worker:prod": "tsx src/worker/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": ">=0.40.0 <1.0.0",
    "@prisma/client": "^6.2.1",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "next": "14.2.35",
    "node-html-parser": "^6.1.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
