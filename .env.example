# ----------------------------------------------------------------------------
# SentinelScan environment configuration
# Copy to `.env` and adjust. `docker compose up -d` provisions Postgres + Redis
# matching the defaults below.
# ----------------------------------------------------------------------------

# PostgreSQL connection (multi-tenant persistence)
DATABASE_URL="postgresql://sentinel:sentinel@localhost:5432/sentinel?schema=public"

# Redis connection (BullMQ job queue + live-log pub/sub)
REDIS_URL="redis://localhost:6379"

# Anthropic API key — enables the Claude Opus 4.8 *dynamic workflow* orchestrator.
# When unset, the scanner falls back to the deterministic engine (still fully
# functional, but the AI-driven adaptive step selection is disabled).
ANTHROPIC_API_KEY=""

# Model used for the dynamic workflow. Do not change unless you know why.
SENTINEL_MODEL="claude-opus-4-8"

# Public base URL of this app (used for the domain-ownership verification file).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Safety: comma-separated allowlist of hosts that may be scanned WITHOUT
# ownership verification (e.g. your own staging domains, or scanme.sh demo
# targets). Leave empty to require verification for every target.
SENTINEL_SCAN_ALLOWLIST=""

# Set to "true" to bypass domain-ownership verification entirely.
# ONLY for local development against targets you are authorized to test.
SENTINEL_SKIP_VERIFICATION="false"
